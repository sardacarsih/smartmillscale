# Smart Mill Scale - Frontend Environment Configuration
# Copy this file to .env and modify values as needed

# Application Configuration
VITE_APP_NAME=Smart Mill Scale
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Sistem Penimbangan Offline dengan Sinkronisasi Cloud

# API Configuration
VITE_API_BASE_URL=http://localhost:8080
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3
VITE_SYNC_SERVER_URL=https://agronomi.kskgroup.web.id/graphql

# Wails Configuration
VITE_WAILS_MODE=development
VITE_WAILS_HOST=localhost
VITE_WAILS_PORT=34115

# Authentication Configuration
VITE_AUTH_SESSION_TIMEOUT=1800000
VITE_AUTH_WARNING_TIMEOUT=120000

# UI Configuration
VITE_THEME=dark
VITE_LANGUAGE=id
VITE_TIMEZONE=Asia/Jakarta

# Development Configuration
VITE_DEV_MODE=true
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=info

# Feature Flags
VITE_ENABLE_MOCK_SERIAL=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false

# Performance Configuration
VITE_CACHE_ENABLED=true
VITE_LAZY_LOADING=true
VITE_CHUNK_SIZE_WARNING_LIMIT=1000

# Serial Port Configuration
VITE_SERIAL_UPDATE_INTERVAL=1000
VITE_SERIAL_STABILITY_THRESHOLD=3

# Sync Configuration
VITE_SYNC_STATUS_UPDATE_INTERVAL=30000
VITE_SYNC_HISTORY_UPDATE_INTERVAL=60000
VITE_WEIGHT_UPDATE_INTERVAL=1000

# Notification Configuration
VITE_NOTIFICATION_DURATION=5000
VITE_NOTIFICATION_MAX_COUNT=5
VITE_ENABLE_SOUND_NOTIFICATIONS=false

# Chart Configuration
VITE_CHART_ANIMATION_DURATION=750
VITE_CHART_REFRESH_INTERVAL=5000

# Data Export Configuration
VITE_EXPORT_MAX_RECORDS=10000
VITE_EXPORT_BATCH_SIZE=1000

# Security Configuration
VITE_ENABLE_CSP=true
VITE_XSS_PROTECTION=true

# External Services
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# Build Configuration
VITE_BUILD_SOURCE_MAP=true
VITE_BUILD_MINIFY=true
VITE_BUILD_TARGET=es2020
# Smart Mill Scale - Backend Environment Configuration
# Copy this file to .env and adjust values for your environment

# Application Configuration
APP_NAME=Smart Mill Scale
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=false

# Server Configuration
HOST=localhost
PORT=8080

# Database Configuration
DB_TYPE=sqlite
DB_PATH=./data/smartmill.db
DB_MAX_CONNECTIONS=1
DB_MAX_OPEN_CONNECTIONS=1
DB_CONNECTION_MAX_LIFETIME=3600

# Serial Port Configuration
SERIAL_COM_PORT=COM5
SERIAL_BAUD_RATE=9600
SERIAL_DATA_BITS=8
SERIAL_STOP_BITS=1
SERIAL_PARITY=N
SERIAL_TIMEOUT=5s
SERIAL_READ_TIMEOUT=1s
SERIAL_WRITE_TIMEOUT=1s

# Mock Serial Configuration (for development without hardware)
MOCK_SERIAL_ENABLED=false
MOCK_SERIAL_INTERVAL=1000
MOCK_SERIAL_MIN_WEIGHT=0
MOCK_SERIAL_MAX_WEIGHT=20000
MOCK_SERIAL_VARIANCE=50

# Synchronization Configuration
SYNC_ENABLED=true
SYNC_SERVER_URL=https://your-server.com/graphql
SYNC_INTERVAL=5m
SYNC_BATCH_SIZE=50
SYNC_MAX_RETRIES=5
SYNC_RETRY_DELAY=1s
SYNC_MAX_RETRY_DELAY=60s
SYNC_HEALTH_CHECK_INTERVAL=30s

# Device Configuration
DEVICE_ID_AUTO_GENERATE=true
DEVICE_NAME_DEFAULT=Timbangan Baru
DEVICE_LOCATION_DEFAULT=PKS

# Authentication Configuration
AUTH_SESSION_TIMEOUT=30m
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_REQUIRE_UPPERCASE=true
AUTH_PASSWORD_REQUIRE_LOWERCASE=true
AUTH_PASSWORD_REQUIRE_NUMBERS=true
AUTH_PASSWORD_REQUIRE_SYMBOLS=true

# Security Configuration
# Set this to override the default device-based encryption key
# SMARTMILL_ENCRYPTION_SECRET=your-secret-key-here

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=text
LOG_FILE=./logs/smartmill.log
LOG_MAX_SIZE=10
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=7

# API Configuration
API_RATE_LIMIT=100
API_TIMEOUT=30s
API_RETRY_ATTEMPTS=3

# CORS Configuration
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:34115,http://localhost:34117
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Development Configuration
DEV_FRONTEND_URL=http://localhost:34115
DEV_HOT_RELOAD=true
